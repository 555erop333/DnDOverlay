<Window x:Class="DnDOverlay.NotesMiniAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Блокнот"
        Width="200"
        Height="120"
        MinWidth="150"
        MinHeight="80"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border CornerRadius="2"
            BorderBrush="{DynamicResource AppWindowBorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource AppWindowBackgroundBrush}">
        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource HeaderBackgroundBrush}"
                    Padding="2"
                    MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource MiniAppCloseButtonStyle}"
                            ToolTip="Закрыть"
                            Click="Close_OnClick" />

                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource MiniAppControlButtonStyle}"
                            Margin="0 0 2 0"
                            ToolTip="Очистить"
                            Click="Clear_OnClick">
                        <TextBlock Text="🗑"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ControlButtonForegroundBrush}" />
                    </Button>

                    <ToggleButton x:Name="MiniAppTopmostToggle"
                                  DockPanel.Dock="Right"
                                  Style="{StaticResource MiniAppTopmostToggleStyle}"
                                  Margin="0 0 2 0"
                                  ToolTip="Закрепить"
                                  Click="MiniAppTopmostToggle_OnClick" />

                    <TextBlock Text="Блокнот"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{DynamicResource HeaderTextBrush}"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <TextBox x:Name="NotesTextBox"
                     Grid.Row="1"
                     Margin="2"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="{DynamicResource SurfaceBackgroundBrush}"
                     Foreground="{DynamicResource SurfaceForegroundBrush}"
                     BorderBrush="{DynamicResource PanelBorderBrush}"
                     BorderThickness="1"
                     Padding="2"
                     FontSize="9"
                     FontFamily="Consolas"
                     TextChanged="NotesTextBox_OnTextChanged"
                     PreviewMouseLeftButtonUp="NotesTextBox_OnPreviewMouseLeftButtonUp" />
        </Grid>
    </Border>
</Window>
