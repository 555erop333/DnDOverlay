<Window x:Class="DnDOverlay.DiceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История бросков"
        Width="260"
        Height="200"
        MinWidth="180"
        MinHeight="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="2"
            BorderBrush="{DynamicResource AppWindowBorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource AppWindowBackgroundBrush}">
        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource HeaderBackgroundBrush}"
                    Padding="2"
                    MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Margin="0 0 2 0">
                        <ToggleButton x:Name="HeaderTopmostToggle"
                                      Style="{StaticResource MiniAppTopmostToggleStyle}"
                                      Click="HeaderTopmostToggle_OnClick"
                                      Margin="0 0 1 0" />

                        <Button Style="{StaticResource MiniAppCloseButtonStyle}"
                                ToolTip="Закрыть"
                                Click="Close_OnClick" />
                    </StackPanel>

                    <TextBlock Text="История бросков"
                               Foreground="{DynamicResource HeaderTextBrush}"
                               FontSize="10"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <ListBox x:Name="HistoryList"
                     Grid.Row="1"
                     Margin="0,2,0,0"
                     Background="{DynamicResource PanelBackgroundBrush}"
                     Foreground="{DynamicResource SurfaceForegroundBrush}"
                     BorderBrush="{DynamicResource PanelBorderBrush}"
                     BorderThickness="1"
                     FontSize="9"
                     Padding="2"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Grid>
    </Border>
</Window>
