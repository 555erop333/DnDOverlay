<Window x:Class="DnDOverlay.StatsMiniAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статы"
        Width="320"
        Height="300"
        MinWidth="150"
        MinHeight="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>


        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="2"
            BorderBrush="{DynamicResource AppWindowBorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource AppWindowBackgroundBrush}">
        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource HeaderBackgroundBrush}"
                    Padding="2"
                    MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Margin="0 0 2 0">
                        <ToggleButton x:Name="MiniAppTopmostToggle"
                                      Style="{StaticResource MiniAppTopmostToggleStyle}"
                                      Click="MiniAppTopmostToggle_OnClick" />

                        <Button Style="{StaticResource MiniAppCloseButtonStyle}"
                                ToolTip="Закрыть"
                                Click="Close_OnClick" />
                    </StackPanel>

                    <TextBlock Text="Статы"
                               Foreground="{DynamicResource HeaderTextBrush}"
                               FontSize="10"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal"
                            Grid.Row="0"
                            Margin="0 0 0 2" />

                <DataGrid x:Name="SkillsGrid"
                          Grid.Row="1"
                          ItemsSource="{Binding Skills}"
                          HeadersVisibility="Column"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          CanUserResizeColumns="False"
                          CanUserSortColumns="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Margin="0 0 0 2"
                          Background="{DynamicResource SurfaceBackgroundBrush}"
                          Foreground="{DynamicResource SurfaceForegroundBrush}"
                          BorderBrush="{DynamicResource PanelBorderBrush}"
                          BorderThickness="1"
                          RowHeight="22"
                          FontSize="9"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource PanelBorderBrush}"
                          VerticalGridLinesBrush="{DynamicResource PanelBorderBrush}">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="4,2" />
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource ControlButtonForegroundBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="Padding" Value="4,0" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0 2 0 2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Редактировать"
                            Height="18"
                            Padding="6 0"
                            FontSize="9"
                            Click="ManagePlayers_OnClick" />

                    <Button Grid.Column="2"
                            Content="Очистить историю"
                            Height="18"
                            Padding="4 0"
                            FontSize="9"
                            HorizontalAlignment="Right"
                            Click="ClearHistory_OnClick" />
                </Grid>

                <ListBox x:Name="RollHistoryList"
                         Grid.Row="3"
                         Background="{DynamicResource ControlButtonBackgroundBrush}"
                         BorderBrush="{DynamicResource ControlButtonBorderBrush}"
                         BorderThickness="1"
                         Foreground="{DynamicResource ControlButtonForegroundBrush}"
                         Padding="2"
                         ItemsSource="{Binding RollHistory}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" />
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0 0 0 2" />
                            <Setter Property="Padding" Value="2" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="FontSize" Value="10" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlButtonPressedBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PlayerName}"
                                           FontWeight="SemiBold"
                                           Margin="0 0 4 0"
                                           Foreground="{DynamicResource SurfaceForegroundBrush}" />
                                <TextBlock Text=":" Foreground="{DynamicResource SurfaceForegroundBrush}" Margin="0 0 4 0" />
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Roll}" />
                                            <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCriticalSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="#FF1CD95C" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                    <Setter Property="FontSize" Value="12" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsCriticalFailure}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFFF4242" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                    <Setter Property="FontSize" Value="12" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding ModifierDisplay}"
                                           Foreground="{DynamicResource SurfaceForegroundBrush}"
                                           Margin="4 0 0 0" />
                                <TextBlock Text="=" Foreground="{DynamicResource SurfaceForegroundBrush}" Margin="4 0 0 0" />
                                <TextBlock Text="{Binding Total}"
                                           Foreground="{DynamicResource SurfaceForegroundBrush}"
                                           Margin="4 0 0 0" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>
