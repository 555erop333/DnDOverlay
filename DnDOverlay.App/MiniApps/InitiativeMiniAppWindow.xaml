<Window x:Class="DnDOverlay.InitiativeMiniAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Инициатива"
        Width="650"
        Height="400"
        MinWidth="500"
        MinHeight="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="MiniAppInlineButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ControlButtonBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlButtonBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{DynamicResource ControlButtonForegroundBrush}" />
                <Setter Property="Padding" Value="2 0" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlButtonPressedBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Border" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="MiniAppColorSwatchButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="12" />
                <Setter Property="Height" Value="12" />
                <Setter Property="Margin" Value="2,0,0,0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlButtonBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="ToolTip" Value="Пометить цветом" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="SwatchBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SwatchBorder" Property="Opacity" Value="1" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="SwatchBorder" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="MiniAppCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="Box"
                                        Width="14"
                                        Height="14"
                                        Background="{DynamicResource ControlButtonBackgroundBrush}"
                                        BorderBrush="{DynamicResource ControlButtonBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2">
                                    <Path x:Name="CheckMark"
                                          Data="M 2 7 L 5 10 L 12 2"
                                          Stroke="{DynamicResource ControlButtonForegroundBrush}"
                                          StrokeThickness="2"
                                          StrokeEndLineCap="Round"
                                          StrokeStartLineCap="Round"
                                          Visibility="Collapsed" />
                                </Border>
                                <ContentPresenter Margin="4 0 0 0"
                                                  VerticalAlignment="Center" />
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Box" Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Box" Property="Opacity" Value="0.5" />
                                    <Setter Property="Foreground" Value="{DynamicResource ControlButtonBorderBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <ControlTemplate x:Key="MiniAppComboBoxToggleButton" TargetType="ToggleButton">
                <Border x:Name="ToggleBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>
                        <ContentPresenter x:Name="ToggleContent"
                                          Margin="4,0,0,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <Path x:Name="Arrow"
                              Grid.Column="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 0 L 4 4 L 8 0 Z"
                              Fill="{DynamicResource ControlButtonForegroundBrush}"
                              Stretch="Fill"
                              Width="8"
                              Height="4" />
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ControlButtonPressedBrush}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.6" />
                        <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource ControlButtonBorderBrush}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <Style x:Key="MiniAppComboBoxItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}" />
                <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
                <Setter Property="Padding" Value="4 2" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlButtonPressedBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource ControlButtonForegroundBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="MiniAppComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="2" />
                <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              Template="{StaticResource MiniAppComboBoxToggleButton}"
                                              Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              Foreground="{TemplateBinding Foreground}"
                                              Padding="{TemplateBinding Padding}"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding ItemTemplate}" />
                                <Popup x:Name="Popup"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       PlacementTarget="{Binding ElementName=ToggleButton}">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource SurfaceBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            MaxHeight="200">
                                        <ScrollViewer Margin="0"
                                                      SnapsToDevicePixels="True">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter TargetName="DropDownBorder" Property="MinHeight" Value="20" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource ControlButtonBorderBrush}" />
                                </Trigger>
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource ControlButtonPressedBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="MiniAppSpinnerButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ControlButtonBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ControlButtonForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlButtonBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="FontSize" Value="7" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="SpinnerBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="0" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SpinnerBorder" Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="SpinnerBorder" Property="Background" Value="{DynamicResource ControlButtonPressedBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="SpinnerBorder" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="2"
            BorderBrush="{DynamicResource AppWindowBorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource AppWindowBackgroundBrush}">
        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource HeaderBackgroundBrush}"
                    Padding="2"
                    MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Margin="0 0 2 0">
                        <ToggleButton x:Name="MiniAppTopmostToggle"
                                      Style="{StaticResource MiniAppTopmostToggleStyle}"
                                      Click="MiniAppTopmostToggle_OnClick" />

                        <Button Style="{StaticResource MiniAppCloseButtonStyle}"
                                ToolTip="Закрыть"
                                Click="Close_OnClick" />
                    </StackPanel>

                    <TextBlock Text="Инициатива"
                               Foreground="{DynamicResource HeaderTextBrush}"
                               FontSize="10"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Панель управления раундами -->
                <Grid Grid.Row="0" Margin="0,2,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0"
                            Content="Очистить бой"
                            Height="18"
                            Padding="4,0"
                            Margin="4,0,2,0"
                            FontSize="9"
                            Style="{StaticResource MiniAppActionButtonStyle}"
                            Click="ClearCombat_Click" />
                    
                    <Button Grid.Column="1"
                            Content="Пресеты"
                            Height="18"
                            Padding="4,0"
                            Margin="2,0,4,0"
                            FontSize="9"
                            Style="{StaticResource MiniAppActionButtonStyle}"
                            Click="Presets_Click" />

                    <Button Grid.Column="2"
                            Content="Журнал"
                            Height="18"
                            Padding="4,0"
                            Margin="0,0,4,0"
                            FontSize="9"
                            Style="{StaticResource MiniAppActionButtonStyle}"
                            Click="BattleLog_Click" />

                    <TextBlock x:Name="RoundCounter"
                               Grid.Column="3"
                               Text="Раунд 1"
                               Foreground="{DynamicResource SurfaceForegroundBrush}"
                               FontSize="11"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />

                    <Button Grid.Column="4"
                            Content="Следующий раунд"
                            Height="18"
                            Padding="4,0"
                            Margin="4,0"
                            FontSize="9"
                            Style="{StaticResource MiniAppActionButtonStyle}"
                            Click="NextRound_Click" />
                </Grid>

                <!-- Панель добавления существ -->
                <Border Grid.Row="1"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        Padding="4"
                        Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Имя -->
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="Имя" Foreground="{DynamicResource SurfaceForegroundBrush}" FontSize="8" />
                            <TextBox x:Name="NameInput"
                                     Height="20"
                                     Background="{DynamicResource InputBackgroundBrush}"
                                     Foreground="{DynamicResource InputForegroundBrush}"
                                     BorderBrush="{DynamicResource PanelBorderBrush}"
                                     BorderThickness="1"
                                     Padding="2"
                                     FontSize="9"
                                     VerticalContentAlignment="Center" />
                        </StackPanel>

                        <!-- Выбор пресета -->
                        <StackPanel Grid.Column="1" Margin="0,0,4,0">
                            <TextBlock Text="Пресет" Foreground="{DynamicResource SurfaceForegroundBrush}" FontSize="8" />
                            <ComboBox x:Name="PresetComboBox"
                                      Width="100"
                                      Height="20"
                                      FontSize="9"
                                      Style="{StaticResource MiniAppComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource MiniAppComboBoxItemStyle}"
                                      SelectionChanged="PresetComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource InputForegroundBrush}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Модификатор инициативы -->
                        <StackPanel Grid.Column="2" Margin="0,0,4,0">
                            <TextBlock Text="Мод. иниц." Foreground="{DynamicResource SurfaceForegroundBrush}" FontSize="8" />
                            <Grid>
                                <Border Background="{DynamicResource InputBackgroundBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        Width="60"
                                        Height="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="InitModInput"
                                                 Grid.Column="0"
                                                 Text="0"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource InputForegroundBrush}"
                                                 BorderThickness="0"
                                                 Padding="2"
                                                 FontSize="9"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 PreviewTextInput="NumberValidationTextBox"
                                                 TextChanged="InitModInput_TextChanged" />
                                        <StackPanel Grid.Column="1" Width="16">
                                            <Button x:Name="InitModUp"
                                                    Content="▲"
                                                    Height="10"
                                                    Style="{StaticResource MiniAppSpinnerButtonStyle}"
                                                    Click="InitModUp_Click" />
                                            <Button x:Name="InitModDown"
                                                    Content="▼"
                                                    Height="10"
                                                    Style="{StaticResource MiniAppSpinnerButtonStyle}"
                                                    Click="InitModDown_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- ХП -->
                        <StackPanel Grid.Column="3" Margin="0,0,4,0">
                            <TextBlock Text="ХП" Foreground="{DynamicResource SurfaceForegroundBrush}" FontSize="8" />
                            <TextBox x:Name="HpInput"
                                     Width="50"
                                     Height="20"
                                     Background="{DynamicResource InputBackgroundBrush}"
                                     Foreground="{DynamicResource InputForegroundBrush}"
                                     BorderBrush="{DynamicResource PanelBorderBrush}"
                                     BorderThickness="1"
                                     Padding="2"
                                     FontSize="9"
                                     VerticalContentAlignment="Center"
                                     PreviewTextInput="NumberValidationTextBox" />
                        </StackPanel>

                        <!-- Класс Доспеха -->
                        <StackPanel Grid.Column="4" Margin="0,0,4,0">
                            <TextBlock Text="КД" Foreground="{DynamicResource SurfaceForegroundBrush}" FontSize="8" />
                            <TextBox x:Name="AcInput"
                                     Width="50"
                                     Height="20"
                                     Background="{DynamicResource InputBackgroundBrush}"
                                     Foreground="{DynamicResource InputForegroundBrush}"
                                     BorderBrush="{DynamicResource PanelBorderBrush}"
                                     BorderThickness="1"
                                     Padding="2"
                                     FontSize="9"
                                     VerticalContentAlignment="Center"
                                     PreviewTextInput="PositiveNumberValidationTextBox" />
                        </StackPanel>

                        <!-- Количество -->
                        <StackPanel Grid.Column="5" Margin="0,0,4,0">
                            <TextBlock Text="Кол-во" Foreground="{DynamicResource SurfaceForegroundBrush}" FontSize="8" />
                            <Grid>
                                <Border Background="{DynamicResource InputBackgroundBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        Width="45"
                                        Height="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CountInput"
                                                 Grid.Column="0"
                                                 Text="1"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource InputForegroundBrush}"
                                                 BorderThickness="0"
                                                 Padding="2"
                                                 FontSize="9"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 PreviewTextInput="NumberValidationTextBox"
                                                 TextChanged="CountInput_TextChanged" />
                                        <StackPanel Grid.Column="1" Width="16">
                                            <Button x:Name="CountUp"
                                                    Content="▲"
                                                    Height="10"
                                                    Style="{StaticResource MiniAppSpinnerButtonStyle}"
                                                    Click="CountUp_Click" />
                                            <Button x:Name="CountDown"
                                                    Content="▼"
                                                    Height="10"
                                                    Style="{StaticResource MiniAppSpinnerButtonStyle}"
                                                    Click="CountDown_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Кнопка добавления -->
                        <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                            <Button Content="Добавить"
                                    Height="20"
                                    Padding="6,0"
                                    FontSize="9"
                                    Style="{StaticResource MiniAppActionButtonStyle}"
                                    Click="Add_OnClick" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Таблица боя -->
                <DataGrid x:Name="CombatGrid"
                          Grid.Row="2"
                          Background="{DynamicResource SurfaceBackgroundBrush}"
                          Foreground="{DynamicResource SurfaceForegroundBrush}"
                          BorderBrush="{DynamicResource PanelBorderBrush}"
                          BorderThickness="1"
                          FontSize="9"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="{DynamicResource PanelBorderBrush}"
                          VerticalGridLinesBrush="{DynamicResource PanelBorderBrush}"
                          HeadersVisibility="Column"
                          SelectionMode="Single">
                    <DataGrid.Resources>
                        <Style x:Key="CenteredCellTextStyle" TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="TextAlignment" Value="Center" />
                        </Style>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}" />
                            <Setter Property="FontSize" Value="9" />
                            <Setter Property="Height" Value="22" />
                            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDead}" Value="True">
                                    <Setter Property="Background" Value="#55666666" />
                                    <Setter Property="Foreground" Value="#88FFFFFF" />
                                    <Setter Property="Opacity" Value="0.6" />
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="2" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <!-- Имя + групповые цвета -->
                        <DataGridTemplateColumn Header="Имя" Width="165">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="2"
                                            Margin="1,0">
                                        <Border.Background>
                                            <Binding Path="GroupColorBrush" TargetNullValue="{StaticResource PanelBackgroundBrush}" />
                                        </Border.Background>
                                        <DockPanel VerticalAlignment="Center">
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal"
                                                        Margin="4,0,0,0"
                                                        HorizontalAlignment="Right">
                                                <Button Style="{StaticResource MiniAppColorSwatchButtonStyle}"
                                                        Background="#44FF6B6B"
                                                        Tag="#44FF6B6B"
                                                        Click="GroupColorButton_Click" />
                                                <Button Style="{StaticResource MiniAppColorSwatchButtonStyle}"
                                                        Background="#44FFD166"
                                                        Tag="#44FFD166"
                                                        Click="GroupColorButton_Click" />
                                                <Button Style="{StaticResource MiniAppColorSwatchButtonStyle}"
                                                        Background="#4458C8FF"
                                                        Tag="#4458C8FF"
                                                        Click="GroupColorButton_Click" />
                                                <Button Style="{StaticResource MiniAppColorSwatchButtonStyle}"
                                                        Background="#4434EBC3"
                                                        Tag="#4434EBC3"
                                                        Click="GroupColorButton_Click" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource SurfaceForegroundBrush}"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- Инициатива -->
                        <DataGridTextColumn Header="Иниц."
                                            Binding="{Binding Initiative}"
                                            Width="40"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource CenteredCellTextStyle}"
                                            EditingElementStyle="{StaticResource CenteredCellTextStyle}" />
                        
                        <!-- Модификатор -->
                        <DataGridTextColumn Header="Мод."
                                            Binding="{Binding InitiativeModifierDisplay}"
                                            Width="40"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource CenteredCellTextStyle}"
                                            EditingElementStyle="{StaticResource CenteredCellTextStyle}" />

                        <!-- Класс доспеха -->
                        <DataGridTextColumn Header="КД"
                                            Binding="{Binding ArmorClass}"
                                            Width="40"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource CenteredCellTextStyle}"
                                            EditingElementStyle="{StaticResource CenteredCellTextStyle}" />
                        
                        <!-- ХП -->
                        <DataGridTemplateColumn Header="ХП" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="4,2"
                                            CornerRadius="2"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource StatusGoodBackgroundBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HealthStatus}" Value="Warning">
                                                        <Setter Property="Background" Value="{DynamicResource StatusWarningBackgroundBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HealthStatus}" Value="Danger">
                                                        <Setter Property="Background" Value="{DynamicResource StatusDangerBackgroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding HpDisplay}"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource StatusGoodForegroundBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HealthStatus}" Value="Warning">
                                                            <Setter Property="Foreground" Value="{DynamicResource StatusWarningForegroundBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HealthStatus}" Value="Danger">
                                                            <Setter Property="Foreground" Value="{DynamicResource StatusDangerForegroundBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- Сделан ход -->
                        <DataGridTemplateColumn Header="Ход" Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding HasActed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Style="{StaticResource MiniAppCheckBoxStyle}"
                                              Click="HasActedCheckBox_Click" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- Действия -->
                        <DataGridTemplateColumn Header="Действия" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <!-- Урон -->
                                        <StackPanel Orientation="Horizontal" Margin="2,0">
                                            <TextBox x:Name="DamageInput"
                                                     Width="30"
                                                     Height="16"
                                                     FontSize="8"
                                                     Margin="0,0,2,0"
                                                     Tag="{Binding}"
                                                     Background="{DynamicResource InputBackgroundBrush}"
                                                     Foreground="{DynamicResource InputForegroundBrush}"
                                                     BorderBrush="{DynamicResource PanelBorderBrush}"
                                                     PreviewTextInput="NumberValidationTextBox" />
                                            <Button Content="Урон"
                                                    Height="16"
                                                    Padding="2,0"
                                                    FontSize="8"
                                                    Tag="{Binding}"
                                                    Style="{StaticResource MiniAppInlineButtonStyle}"
                                                    Click="DamageButton_Click" />
                                        </StackPanel>
                                        
                                        <!-- Лечение -->
                                        <StackPanel Orientation="Horizontal" Margin="2,0">
                                            <TextBox x:Name="HealInput"
                                                     Width="30"
                                                     Height="16"
                                                     FontSize="8"
                                                     Margin="0,0,2,0"
                                                     Tag="{Binding}"
                                                     Background="{DynamicResource InputBackgroundBrush}"
                                                     Foreground="{DynamicResource InputForegroundBrush}"
                                                     BorderBrush="{DynamicResource PanelBorderBrush}"
                                                     PreviewTextInput="NumberValidationTextBox" />
                                            <Button Content="Хил"
                                                    Height="16"
                                                    Padding="2,0"
                                                    FontSize="8"
                                                    Tag="{Binding}"
                                                    Style="{StaticResource MiniAppInlineButtonStyle}"
                                                    Click="HealButton_Click" />
                                        </StackPanel>
                                        
                                        <!-- Временные ХП -->
                                        <StackPanel Orientation="Horizontal" Margin="2,0">
                                            <TextBox x:Name="TempHpInput"
                                                     Width="30"
                                                     Height="16"
                                                     FontSize="8"
                                                     Margin="0,0,2,0"
                                                     Tag="{Binding}"
                                                     Background="{DynamicResource InputBackgroundBrush}"
                                                     Foreground="{DynamicResource InputForegroundBrush}"
                                                     BorderBrush="{DynamicResource PanelBorderBrush}"
                                                     PreviewTextInput="NumberValidationTextBox" />
                                            <Button Content="Врем.ХП"
                                                    Height="16"
                                                    Padding="2,0"
                                                    FontSize="8"
                                                    Tag="{Binding}"
                                                    Style="{StaticResource MiniAppInlineButtonStyle}"
                                                    Click="TempHpButton_Click" />
                                        </StackPanel>
                                        
                                        <!-- Убить -->
                                        <Button Content="X"
                                                Height="16"
                                                Width="16"
                                                Padding="0"
                                                FontSize="8"
                                                FontWeight="Bold"
                                                Margin="4,0,0,0"
                                                Tag="{Binding}"
                                                Style="{StaticResource MiniAppInlineButtonStyle}"
                                                Click="KillButton_Click"
                                                ToolTip="Вывести из боя" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Border>
</Window>
