<Window x:Class="DnDOverlay.YouTubeCookieLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="YouTube авторизация" Height="600" Width="900"
        WindowStartupLocation="CenterOwner">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Background="#FFE8F0FF" BorderBrush="#FF1E6ACB" BorderThickness="0,0,0,1" Padding="12">
      <StackPanel>
        <TextBlock Text="Авторизуйтесь на YouTube в окне ниже. После входа нажмите 'Сохранить куки'."
                   FontWeight="Bold" Margin="0 0 0 4" />
        <TextBlock Text="Мы сохраним файл cookies локально и будем использовать его для yt-dlp."
                   TextWrapping="Wrap" />
        <TextBlock x:Name="StatusTextBlock" Margin="0 8 0 0" Foreground="#FF1E6ACB" />
      </StackPanel>
    </Border>

    <wpf:WebView2 x:Name="YouTubeWebView" Grid.Row="1" Margin="0" />

    <DockPanel Grid.Row="2" Margin="12">
      <Button Content="Открыть YouTube" Width="140" Margin="0 0 8 0" Click="OpenYouTubeButton_OnClick" />
      <DockPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Удалить куки" Width="140" Margin="0 0 8 0" Click="DeleteCookiesButton_OnClick" />
          <Button Content="Сохранить куки" Width="140" Margin="0 0 8 0" Click="SaveCookiesButton_OnClick" />
          <Button Content="Закрыть" Width="100" Click="CloseButton_OnClick" />
        </StackPanel>
      </DockPanel>
    </DockPanel>
  </Grid>
</Window>
