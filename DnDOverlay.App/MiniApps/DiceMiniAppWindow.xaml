<Window x:Class="DnDOverlay.DiceMiniAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DnDOverlay"
        Title="Кубы"
        Width="360"
        Height="25"
        MinWidth="601"
        MinHeight="46"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        PreviewMouseLeftButtonDown="Window_OnPreviewMouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="TriangleButtonPlusStyle" TargetType="Button">
                <Setter Property="Width" Value="18" />
                <Setter Property="Height" Value="18" />
                <Setter Property="Background" Value="{DynamicResource ControlButtonBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlButtonBorderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ControlButtonForegroundBrush}" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Path x:Name="Triangle"
                                      Data="M0,0 L1,0 L1,1 Z"
                                      Stretch="Fill"
                                      Fill="{TemplateBinding Background}"
                                      Stroke="{TemplateBinding BorderBrush}"
                                      StrokeThickness="1" />
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform X="5" Y="-5" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Triangle" Property="Fill" Value="{DynamicResource ControlButtonHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Triangle" Property="Fill" Value="{DynamicResource ControlButtonPressedBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TriangleButtonMinusStyle" TargetType="Button">
                <Setter Property="Width" Value="18" />
                <Setter Property="Height" Value="18" />
                <Setter Property="Background" Value="{DynamicResource ControlButtonBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlButtonBorderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ControlButtonForegroundBrush}" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Path x:Name="Triangle"
                                      Data="M0,0 L0,1 L1,1 Z"
                                      Stretch="Fill"
                                      Fill="{TemplateBinding Background}"
                                      Stroke="{TemplateBinding BorderBrush}"
                                      StrokeThickness="1" />
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform X="-3" Y="3" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Triangle" Property="Fill" Value="#55FFFFFF" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Triangle" Property="Fill" Value="#AAFFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="2"
            BorderBrush="{DynamicResource AppWindowBorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource AppWindowBackgroundBrush}">
        <Grid Margin="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                        <ItemsControl x:Name="DiceEntriesList"
                                      Margin="0,0,4,0"
                                      VerticalAlignment="Bottom">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,4,0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource SurfaceForegroundBrush}"
                                                   HorizontalAlignment="Center" />
                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0" VerticalAlignment="Center">
                                            <TextBox Width="20"
                                                     Height="18"
                                                     Margin="0,0,1,0"
                                                     Background="{DynamicResource InputBackgroundBrush}"
                                                     Foreground="{DynamicResource InputForegroundBrush}"
                                                     BorderBrush="{DynamicResource PanelBorderBrush}"
                                                     BorderThickness="1"
                                                     Padding="2,0"
                                                     FontSize="9"
                                                     HorizontalContentAlignment="Center"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding CountText, UpdateSourceTrigger=PropertyChanged}"
                                                     GotKeyboardFocus="TextBox_SelectAll_OnGotKeyboardFocus"
                                                     PreviewMouseLeftButtonDown="TextBox_SelectAll_OnPreviewMouseLeftButtonDown"
                                                     MouseDoubleClick="DiceCountTextBox_OnMouseDoubleClick"
                                                     PreviewTextInput="DiceCountTextBox_OnPreviewTextInput"
                                                     DataObject.Pasting="DiceCountTextBox_OnPasting" />
                                            <Grid Width="18"
                                                  Height="18">
                                                <Button Style="{StaticResource TriangleButtonPlusStyle}"
                                                        Content="+"
                                                        Click="DicePlus_OnClick" />
                                                <Button Style="{StaticResource TriangleButtonMinusStyle}"
                                                        Content="-"
                                                        Click="DiceMinus_OnClick" />
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Width="1"
                                   Margin="2,0"
                                   Background="{DynamicResource PanelBorderBrush}"
                                   Visibility="Visible" />

                        <StackPanel Margin="4,0,0,0"
                                    VerticalAlignment="Bottom">
                            <TextBlock Text="Мод"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SurfaceForegroundBrush}"
                                       HorizontalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" Margin="0,1,0,0" VerticalAlignment="Center">
                                <TextBox x:Name="ModifierInput"
                                         Width="20"
                                         Height="18"
                                         Margin="0,0,1,0"
                                         Background="{DynamicResource InputBackgroundBrush}"
                                         Foreground="{DynamicResource InputForegroundBrush}"
                                         BorderBrush="{DynamicResource PanelBorderBrush}"
                                         BorderThickness="1"
                                         Padding="2,0"
                                         FontSize="9"
                                         HorizontalContentAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Text="0"
                                         GotKeyboardFocus="TextBox_SelectAll_OnGotKeyboardFocus"
                                         PreviewMouseLeftButtonDown="TextBox_SelectAll_OnPreviewMouseLeftButtonDown"
                                         MouseDoubleClick="ModifierInput_OnMouseDoubleClick"
                                         PreviewTextInput="ModifierInput_OnPreviewTextInput"
                                         DataObject.Pasting="ModifierInput_OnPasting"
                                         LostFocus="ModifierInput_OnLostFocus" />
                                <Grid Width="18"
                                      Height="18">
                                    <Button Style="{StaticResource TriangleButtonPlusStyle}"
                                            Content="+"
                                            Click="ModifierPlus_OnClick" />
                                    <Button Style="{StaticResource TriangleButtonMinusStyle}"
                                            Content="-"
                                            Click="ModifierMinus_OnClick" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <Separator Width="1"
                                   Margin="2,0"
                                   Background="#55FFFFFF"
                                   Visibility="Visible" />

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Bottom"
                                    Margin="4,0,0,0">
                            <Button Content="Бросить"
                                    Height="18"
                                    Padding="6,0"
                                    FontSize="9"
                                    Margin="0,0,2,0"
                                    Background="{DynamicResource ControlButtonBackgroundBrush}"
                                    Foreground="{DynamicResource ControlButtonForegroundBrush}"
                                    BorderBrush="{DynamicResource ControlButtonBorderBrush}"
                                    Click="Roll_OnClick" />
                            <Button x:Name="HistoryToggleButton"
                                    Content="История"
                                    Height="18"
                                    Padding="6,0"
                                    FontSize="9"
                                    Margin="0,0,2,0"
                                    Background="{DynamicResource ControlButtonBackgroundBrush}"
                                    Foreground="{DynamicResource ControlButtonForegroundBrush}"
                                    BorderBrush="{DynamicResource ControlButtonBorderBrush}"
                                    Click="HistoryToggleButton_OnClick" />
                            <Border Background="{DynamicResource SurfaceBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="6 0"
                                    Margin="4,0,0,0"
                                    Width="65"
                                    VerticalAlignment="Bottom">
                                <TextBlock x:Name="ResultText"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource SurfaceForegroundBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

            <StackPanel Grid.Column="1"
                        Margin="4 0 0 4"
                        VerticalAlignment="Bottom">
                <ToggleButton x:Name="MiniAppTopmostToggle"
                              Style="{StaticResource MiniAppTopmostToggleStyle}"
                              Click="MiniAppTopmostToggle_OnClick"
                              Margin="0 0 0 4" />
                <Button Style="{StaticResource MiniAppCloseButtonStyle}"
                        ToolTip="Закрыть"
                        Click="Close_OnClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
