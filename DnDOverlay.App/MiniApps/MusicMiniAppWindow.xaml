                          CommandParameter="4"
                          Click="DeckClearButton_OnClick" />
                </Grid>
                <TextBlock Grid.Row="1" x:Name="Deck4NowLabel" Text="Перетащите сюда трек" Foreground="{DynamicResource SurfaceForegroundBrush}" TextTrimming="CharacterEllipsis" PreviewMouseMove="DeckNowLabel_OnPreviewMouseMove"/>
                <StackPanel Grid.Row="2" Orientation="Vertical">
