                  </WrapPanel>
                </StackPanel>
              </Grid>
            </Border>
          </Grid>
        </ScrollViewer>
      </Grid>

      <Grid x:Name="ToolInstallOverlay"
            Visibility="Collapsed"
            Background="{DynamicResource AppWindowBorderBrush}"
            Opacity="0.65"
            Panel.ZIndex="200"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border CornerRadius="6"
                Padding="16"
                Background="{DynamicResource AppWindowBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="320">
          <StackPanel>
            <TextBlock Text="Подготовка инструментов"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SurfaceForegroundBrush}"
                       TextAlignment="Center" />
            <TextBlock x:Name="ToolInstallMessageTextBlock"
                       Margin="0 12 0 8"
                       FontSize="12"
                       Foreground="{DynamicResource SurfaceForegroundBrush}"
                       Opacity="0.85"
                       TextWrapping="Wrap"
                       Text="Загрузка зависимостей..." />
            <ProgressBar IsIndeterminate="True"
                         Height="12"
                         Margin="0 0 0 12" />
            <Button Content="Отмена"
                    Width="100"
                    HorizontalAlignment="Center"
                    Click="ToolInstallCancelButton_OnClick" />
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Border>
</Window>
