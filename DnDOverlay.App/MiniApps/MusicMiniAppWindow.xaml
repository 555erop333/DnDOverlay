                      <Slider.Resources>
                        <Style TargetType="Thumb" BasedOn="{StaticResource DeckSliderThumbStyle}" />
                      </Slider.Resources>
                    </Slider>
                    <Button Content="Затух" Width="56" Height="20" Margin="6 0 0 2" Click="Deck4FadeButton_OnClick" />
                    <TextBlock Text="Вывод" VerticalAlignment="Center" Foreground="{DynamicResource SurfaceForegroundBrush}" Margin="4 0 4 2"/>
