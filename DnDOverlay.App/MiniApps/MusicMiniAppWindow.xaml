<Window x:Class="DnDOverlay.MusicMiniAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DnDOverlay"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Музыка"
        Width="900"
        Height="520"
        MinWidth="215"
        MinHeight="205"
        WindowStyle="None"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        PreviewMouseMove="Window_OnPreviewMouseMove">
  <WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        CornerRadius="2"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="4"
                        UseAeroCaptionButtons="False" />
  </WindowChrome.WindowChrome>
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <Style x:Key="DeckClearButtonStyle" TargetType="Button">
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="ButtonBorder"
                      Width="16"
                      Height="16"
                      Background="{DynamicResource ControlButtonBackgroundBrush}"
                      BorderBrush="{DynamicResource ControlButtonBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="2">
                <TextBlock Text="✕"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ControlButtonForegroundBrush}" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlButtonPressedBrush}" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ToolTip" Value="Очистить деку" />
      </Style>

      <Style x:Key="DeckOutputComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4 0" />
        <Setter Property="ItemContainerStyle">
          <Setter.Value>
            <Style TargetType="ComboBoxItem">
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}" />
              <Setter Property="Padding" Value="4 2" />
              <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                  <Setter Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                  <Setter Property="Background" Value="{DynamicResource ControlButtonPressedBrush}" />
                  <Setter Property="Foreground" Value="{DynamicResource HeaderTextBrush}" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="DeckSliderThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Background" Value="{DynamicResource ControlButtonForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
      </Style>

      <Style x:Key="MusicTabItemStyle" TargetType="TabItem">
        <Setter Property="Margin" Value="0 0 4 0" />
        <Setter Property="Padding" Value="10 4" />
        <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="TabItem">
              <Border x:Name="TabBorder"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{DynamicResource PanelBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="3"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter x:Name="ContentSite"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  ContentSource="Header"
                                  RecognizesAccessKey="True" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                  <Setter Property="Foreground" Value="{DynamicResource HeaderTextBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                  <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ControlButtonPressedBrush}" />
                  <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ControlButtonBorderBrush}" />
                  <Setter Property="Foreground" Value="{DynamicResource HeaderTextBrush}" />
                  <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="TabBorder" Property="Opacity" Value="0.5" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="MusicFilterTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4 0" />
        <Setter Property="CaretBrush" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource ControlButtonHoverBrush}" />
      </Style>

      <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="4" />
        <Setter Property="MinWidth" Value="4" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ControlButtonForegroundBrush}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Grid Width="{TemplateBinding Width}" Background="Transparent">
                <Grid.RowDefinitions>
                  <RowDefinition Height="0" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="0" />
                </Grid.RowDefinitions>

                <RepeatButton Grid.Row="0"
                              Command="ScrollBar.LineUpCommand"
                              Opacity="0"
                              Height="0"
                              IsEnabled="False" />

                <Track x:Name="PART_Track"
                       Grid.Row="1"
                       Orientation="Vertical"
                       IsDirectionReversed="True">
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                  Opacity="0"
                                  IsEnabled="False" />
                  </Track.DecreaseRepeatButton>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                  Opacity="0"
                                  IsEnabled="False" />
                  </Track.IncreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb Background="{TemplateBinding Foreground}"
                           BorderBrush="Transparent"
                           Width="{TemplateBinding Width}"
                           MinHeight="12" />
                  </Track.Thumb>
                </Track>

                <RepeatButton Grid.Row="2"
                              Command="ScrollBar.LineDownCommand"
                              Opacity="0"
                              Height="0"
                              IsEnabled="False" />
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <Trigger Property="Orientation" Value="Horizontal">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Height" Value="4" />
            <Setter Property="MinHeight" Value="4" />
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                  <Grid Height="{TemplateBinding Height}" Background="Transparent">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="0" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="0" />
                    </Grid.ColumnDefinitions>

                    <RepeatButton Grid.Column="0"
                                  Command="ScrollBar.LineLeftCommand"
                                  Opacity="0"
                                  Width="0"
                                  IsEnabled="False" />

                    <Track x:Name="PART_Track"
                           Grid.Column="1"
                           Orientation="Horizontal">
                      <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageLeftCommand"
                                      Opacity="0"
                                      IsEnabled="False" />
                      </Track.DecreaseRepeatButton>
                      <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageRightCommand"
                                      Opacity="0"
                                      IsEnabled="False" />
                      </Track.IncreaseRepeatButton>
                      <Track.Thumb>
                        <Thumb Background="{TemplateBinding Foreground}"
                               BorderBrush="Transparent"
                               Height="{TemplateBinding Height}"
                               MinWidth="12" />
                      </Track.Thumb>
                    </Track>

                    <RepeatButton Grid.Column="2"
                                  Command="ScrollBar.LineRightCommand"
                                  Opacity="0"
                                  Width="0"
                                  IsEnabled="False" />
                  </Grid>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Trigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </Window.Resources>

  <Border CornerRadius="2"
          BorderBrush="{DynamicResource AppWindowBorderBrush}"
          BorderThickness="1"
          Background="{DynamicResource AppWindowBackgroundBrush}">
    <Grid Margin="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Background="{DynamicResource HeaderBackgroundBrush}"
              Padding="2"
              MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
        <DockPanel>
          <StackPanel DockPanel.Dock="Right"
                      Orientation="Horizontal"
                      Margin="0 0 2 0">
            <ToggleButton x:Name="MiniAppTopmostToggle"
                          Width="16"
                          Height="16"
                          Margin="0 0 1 0"
                          ToolTip="Закрепить"
                          Click="MiniAppTopmostToggle_OnClick">
              <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                  <Border x:Name="ButtonBorder"
                          Background="{DynamicResource ControlButtonBackgroundBrush}"
                          BorderBrush="{DynamicResource ControlButtonBorderBrush}"
                          BorderThickness="1">
                    <TextBlock Text="📌"
                               FontSize="9"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ControlButtonForegroundBrush}" />
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                      <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlButtonPressedBrush}" />
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </ToggleButton.Template>
            </ToggleButton>

            <Button Width="16"
                    Height="16"
                    ToolTip="Закрыть"
                    Click="Close_OnClick">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="ButtonBorder"
                          Background="{DynamicResource ControlButtonBackgroundBrush}"
                          BorderBrush="{DynamicResource ControlButtonBorderBrush}"
                          BorderThickness="1">
                    <TextBlock Text="✕"
                               FontSize="11"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ControlButtonForegroundBrush}" />
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </StackPanel>

          <TextBlock Text="Музыка"
                     Foreground="{DynamicResource HeaderTextBrush}"
                     FontSize="10"
                     FontWeight="Bold"
                     VerticalAlignment="Center" />
        </DockPanel>
      </Border>

      <Grid x:Name="MainColumnsGrid" Grid.Row="1" Margin="2" SizeChanged="MainColumnsGrid_OnSizeChanged">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="3*" MinWidth="160" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="8*" MinWidth="220" />
        </Grid.ColumnDefinitions>

        <TabControl x:Name="TrackSourcesTabControl"
                    Grid.Column="0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Padding="0"
                    BorderThickness="0"
                    Background="Transparent"
                    ItemContainerStyle="{StaticResource MusicTabItemStyle}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    SelectionChanged="TrackSourcesTabControl_OnSelectionChanged">
          <TabControl.Template>
            <ControlTemplate TargetType="TabControl">
              <Grid KeyboardNavigation.TabNavigation="Local">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TabPanel x:Name="HeaderPanel"
                          Grid.Row="0"
                          IsItemsHost="True"
                          Margin="0" />
                <ContentPresenter x:Name="PART_SelectedContentHost"
                                  Grid.Row="1"
                                  Margin="0"
                                  ContentSource="SelectedContent" />
              </Grid>
            </ControlTemplate>
          </TabControl.Template>
          <TabItem x:Name="DownloadedTabItem" Header="Скачанные" Padding="6 4">
            <Grid x:Name="PlaylistTabContent">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <Grid Margin="2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilterTextBox"
                         Grid.Column="0"
                         Height="22"
                         MinWidth="120"
                         Margin="0 0 4 0"
                         VerticalAlignment="Center"
                         Style="{StaticResource MusicFilterTextBoxStyle}"
                         ToolTip="Фильтр по имени/описанию/тегам"
                         TextChanged="FilterTextBox_OnTextChanged" />
                <Button Grid.Column="1" Content="🔄" Width="28" Height="22" Click="RefreshPlaylist_OnClick" />
                <Button Grid.Column="2" Content="📂" Width="40" Height="22" Margin="4 0 0 0" Click="OpenMusicFolder_OnClick" />
              </Grid>

              <Border Grid.Row="1"
                      Margin="2"
                      Padding="2"
                      Background="{DynamicResource PanelBackgroundBrush}"
                      BorderBrush="{DynamicResource PanelBorderBrush}"
                      BorderThickness="1">
                <ListBox x:Name="PlaylistListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource SurfaceForegroundBrush}"
                         SelectionChanged="PlaylistListBox_OnSelectionChanged"
                         PreviewMouseMove="PlaylistListBox_OnPreviewMouseMove"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         SnapsToDevicePixels="True">
                  <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                      <Setter Property="Background" Value="Transparent"/>
                      <Setter Property="BorderBrush" Value="Transparent"/>
                      <Setter Property="BorderThickness" Value="0"/>
                      <Setter Property="Padding" Value="0"/>
                      <Setter Property="Margin" Value="0 2"/>
                      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                      <Setter Property="Cursor" Value="Hand"/>
                      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                      <EventSetter Event="MouseLeftButtonUp" Handler="PlaylistItem_OnMouseLeftButtonUp"/>
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="ListBoxItem">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                              <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlButtonHoverBrush}"/>
                              </Trigger>
                              <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlButtonPressedBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ControlButtonBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                              </Trigger>
                            </ControlTemplate.Triggers>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>
                    <Style x:Key="SecondaryText" TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{DynamicResource SurfaceForegroundBrush}"/>
                      <Setter Property="Opacity" Value="0.75"/>
                      <Setter Property="FontSize" Value="11"/>
                    </Style>
                  </ListBox.Resources>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border x:Name="Card"
                              Padding="6"
                              Margin="1"
                              Background="{DynamicResource SurfaceBackgroundBrush}"
                              BorderBrush="{DynamicResource PanelBorderBrush}"
                              BorderThickness="1">
                        <Border.ContextMenu>
                          <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Изменить..." Click="PlaylistEditMenuItem_OnClick" />
                          </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>

                          <Border Width="34"
                                  Height="34"
                                  CornerRadius="8"
                                  Grid.Column="0"
                                  Background="{DynamicResource PanelBackgroundBrush}"
                                  Margin="0 0 6 0"
                                  SnapsToDevicePixels="True">
                            <Grid>
                              <Image x:Name="CoverImage"
                                     Source="{Binding CoverImage}"
                                     Stretch="UniformToFill"
                                     SnapsToDevicePixels="True">
                                <Image.Style>
                                  <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding CoverImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </Image.Style>
                              </Image>
                              <TextBlock x:Name="FallbackIcon"
                                         Text=""
                                         FontFamily="Segoe MDL2 Assets"
                                         FontSize="16"
                                         Foreground="{DynamicResource SurfaceForegroundBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding CoverImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>
                            </Grid>
                          </Border>

                          <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Foreground="{DynamicResource SurfaceForegroundBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <Border Margin="0 4 0 0"
                                    Background="{DynamicResource PanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1">
                              <Grid>
                                <TextBlock x:Name="DescriptionDisplay"
                                           Margin="5 3"
                                           Foreground="{DynamicResource SurfaceForegroundBrush}"
                                           TextWrapping="Wrap"
                                           Background="Transparent"
                                           Loaded="DescriptionTextBlock_OnLoaded"
                                           DataContextChanged="DescriptionTextBlock_OnDataContextChanged"
                                           MouseLeftButtonDown="DescriptionTextBlock_OnMouseLeftButtonDown" />
                              </Grid>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Tags}" Margin="0 4 0 0">
                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <WrapPanel />
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Border Background="{DynamicResource PanelBackgroundBrush}"
                                          BorderBrush="{DynamicResource PanelBorderBrush}"
                                          BorderThickness="1"
                                          Padding="6 2"
                                          Margin="0 4 6 0">
                                    <TextBlock Text="{Binding}"
                                               FontSize="10.5"
                                               Foreground="{DynamicResource SurfaceForegroundBrush}" />
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                              <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tags.Count}" Value="0">
                                      <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </ItemsControl.Style>
                            </ItemsControl>

                          </StackPanel>
                        </Grid>
                      </Border>
                      <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                          <Setter TargetName="Card" Property="Background" Value="{DynamicResource ControlButtonHoverBrush}" />
                          <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ControlButtonBorderBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                          <Setter TargetName="Card" Property="Background" Value="{DynamicResource ControlButtonPressedBrush}" />
                          <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ControlButtonForegroundBrush}" />
                        </DataTrigger>
                      </DataTemplate.Triggers>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>
            </Grid>
          </TabItem>
          <TabItem x:Name="BackgroundTabItem" Header="Фон" Padding="6 4" />
          <TabItem x:Name="YouTubeTabItem" Header="YouTube" Padding="6 4">
            <Grid>
              <Grid x:Name="YouTubeLegacyPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="2">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <DockPanel Grid.Row="0" LastChildFill="False">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                      <Button x:Name="YouTubeAddButton"
                              Content="＋"
                              Width="28"
                              Height="22"
                              Margin="0 0 4 0"
                              ToolTip="Добавить YouTube трек"
                              Click="YouTubeAddButton_OnClick" />
                      <Button x:Name="YouTubeCookiesButton"
                              Content="Авторизоваться"
                              Margin="0 0 4 0"
                              Height="22"
                              MinWidth="110"
                              Visibility="Collapsed"
                              Click="YouTubeCookiesButton_OnClick"
                              LostKeyboardFocus="YouTubeCookiesButton_OnLostKeyboardFocus" />
                      <TextBlock x:Name="YouTubeCookiesSavedIcon"
                                 Text="✅"
                                 Margin="0 0 8 0"
                                 VerticalAlignment="Center"
                                 ToolTip="Куки сохранены. Нажмите для повторной авторизации"
                                 Visibility="Collapsed"
                                 Cursor="Hand"
                                 MouseLeftButtonUp="YouTubeCookiesSavedIcon_OnMouseLeftButtonUp" />
                      <Button x:Name="YouTubeEditButton"
                              Content="Изменить"
                              Margin="0 0 4 0"
                              Height="22"
                              MinWidth="80"
                              Click="YouTubeEditButton_OnClick"
                              IsEnabled="False" />
                      <Button x:Name="YouTubeDownloadAllButton"
                              Content="Скачать все"
                              Margin="0 0 4 0"
                              Height="22"
                              MinWidth="110"
                              Click="YouTubeDownloadAllButton_OnClick" />
                      <Button Content="🔄"
                              Width="28"
                              Height="22"
                              Click="RefreshYouTube_OnClick" />
                    </StackPanel>
                  </DockPanel>

                  <Grid Grid.Row="1" Margin="0 4 0 0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="YouTubeFilterTextBox"
                             Grid.Column="0"
                             Height="22"
                             MinWidth="120"
                             Margin="0 0 4 0"
                             VerticalAlignment="Center"
                             Style="{StaticResource MusicFilterTextBoxStyle}"
                             ToolTip="Фильтр по названию/описанию"
                             TextChanged="YouTubeFilterTextBox_OnTextChanged" />
                    <TextBlock Grid.Column="1"
                               Text="Фильтр"
                               Margin="0 0 0 0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SurfaceForegroundBrush}"
                               Opacity="0.65" />
                  </Grid>
                </Grid>

                <Border Grid.Row="1"
                        Margin="2"
                        Padding="2"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1">
                  <ListBox x:Name="YouTubeListBox"
                           Background="Transparent"
                           BorderThickness="0"
                           Foreground="{DynamicResource SurfaceForegroundBrush}"
                           SelectionChanged="YouTubeListBox_OnSelectionChanged"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                           ScrollViewer.VerticalScrollBarVisibility="Auto"
                           PreviewMouseMove="YouTubeListBox_OnPreviewMouseMove">
                    <ListBox.ItemContainerStyle>
                      <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0 2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        <Setter Property="Cursor" Value="{DynamicResource ControlButtonCursor}"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <EventSetter Event="MouseLeftButtonUp" Handler="YouTubeItem_OnMouseLeftButtonUp"/>
                        <Setter Property="Template">
                          <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                              <Border Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter />
                              </Border>
                              <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                  <Setter Property="Background" Value="{DynamicResource ControlButtonHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                  <Setter Property="Background" Value="{DynamicResource ControlButtonPressedBrush}"/>
                                  <Setter Property="BorderBrush" Value="{DynamicResource ControlButtonBorderBrush}"/>
                                  <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                              </ControlTemplate.Triggers>
                            </ControlTemplate>
                          </Setter.Value>
                        </Setter>
                      </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Padding="6"
                              Margin="1"
                              Background="{DynamicResource SurfaceBackgroundBrush}"
                              BorderBrush="{DynamicResource PanelBorderBrush}"
                              BorderThickness="1">
                        <Border.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                              <MenuItem Header="Изменить..." Click="YouTubeEditMenuItem_OnClick" />
                              <MenuItem Header="Удалить..." Click="YouTubeDeleteMenuItem_OnClick" />
                            </ContextMenu>
                          </Border.ContextMenu>
                          <StackPanel>
                            <DockPanel Margin="0 0 0 4"
                                      LastChildFill="True">
                              <StackPanel Orientation="Horizontal"
                                          DockPanel.Dock="Left"
                                          Margin="0 0 6 0">
                                <TextBlock Text="{Binding DownloadStatusIcon}"
                                           FontWeight="Bold"
                                           Margin="0 6 6 0"
                                           VerticalAlignment="Center">
                                  <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                      <Setter Property="Foreground" Value="{DynamicResource StatusDangerForegroundBrush}" />
                                      <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                          <Setter Property="Foreground" Value="{DynamicResource StatusGoodForegroundBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                          <Setter Property="Foreground" Value="{DynamicResource ControlButtonForegroundBrush}" />
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding DownloadStatusText}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                  <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                      <Setter Property="Foreground" Value="{DynamicResource StatusDangerForegroundBrush}" />
                                      <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                          <Setter Property="Foreground" Value="{DynamicResource StatusGoodForegroundBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                          <Setter Property="Foreground" Value="{DynamicResource ControlButtonForegroundBrush}" />
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </TextBlock.Style>
                                </TextBlock>
                              </StackPanel>
                              <TextBlock Text="{Binding DisplayName}"
                                         FontWeight="SemiBold"
                                         FontSize="12"
                                         Foreground="{DynamicResource SurfaceForegroundBrush}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                              <Button Content="⬇"
                                      Width="28"
                                      Height="20"
                                      Margin="4 0 0 0"
                                      DockPanel.Dock="Right"
                                      ToolTip="Скачать превью"
                                      Command="{x:Static ApplicationCommands.NotACommand}"
                                      Click="YouTubeDownloadPreviewButton_OnClick"
                                      Tag="{Binding}" />
                            </DockPanel>
                            <TextBlock Text="{Binding Description}"
                                       Margin="0 4 0 0"
                                       Foreground="{DynamicResource SurfaceForegroundBrush}"
                                       Opacity="0.85"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding DurationDisplay, TargetNullValue=''}"
                                       Margin="0 2 0 0"
                                       Foreground="{DynamicResource SurfaceForegroundBrush}"
                                       Opacity="0.65"
                                       FontSize="10">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Visibility" Value="Visible" />
                                  <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                      <Setter Property="Visibility" Value="Collapsed" />
                                    </Trigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>
              </Grid>

              <Border Background="{DynamicResource PanelBackgroundBrush}">
                <wv2:WebView2 x:Name="YouTubeWebView"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              NavigationCompleted="YouTubeWebView_OnNavigationCompleted" />
              </Border>
            </Grid>
          </TabItem>
        </TabControl>

        <GridSplitter x:Name="MainGridSplitter" Grid.Column="1" Width="8" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{DynamicResource ControlButtonBorderBrush}" ShowsPreview="False" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Cursor="SizeWE" PreviewMouseLeftButtonUp="Splitter_OnMouseLeftButtonUp" DragCompleted="Splitter_OnDragCompleted" DragDelta="Splitter_OnDragDelta" />
        <Button x:Name="LeftSplitterToggleButton" Grid.Column="1" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" Click="LeftSplitterToggle_OnClick">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="7" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1">
                <TextBlock Text="◀" Foreground="{DynamicResource SurfaceForegroundBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
              </Border>
            </ControlTemplate>
          </Button.Template>
        </Button>

        <ScrollViewer x:Name="DeckColumnScrollViewer" Grid.Column="2" Margin="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    x:Name="Deck1DropArea"
                    Background="{DynamicResource SurfaceBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    AllowDrop="True"
                    Drop="Deck1_OnDrop"
                    DragEnter="Deck_OnDragEnter"
                    DragOver="Deck_OnDragOver"
                    Margin="0 0 0 2">
              <Grid Margin="4">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Дека 1" Foreground="{DynamicResource SurfaceForegroundBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                  <Button Grid.Column="1"
                          Width="16"
                          Height="16"
                          Margin="4 0 0 0"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Style="{StaticResource DeckClearButtonStyle}"
                          CommandParameter="1"
                          Click="DeckClearButton_OnClick" />
                </Grid>
                <TextBlock Grid.Row="1" x:Name="Deck1NowLabel" Text="Перетащите сюда трек" Foreground="{DynamicResource SurfaceForegroundBrush}" TextTrimming="CharacterEllipsis" PreviewMouseMove="DeckNowLabel_OnPreviewMouseMove"/>
                <StackPanel Grid.Row="2" Orientation="Vertical">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="Deck1SeekSlider"
                            Grid.Column="0"
                            Minimum="0"
                            Maximum="1"
                            Height="16"
                            Margin="0 0 6 4"
                            IsMoveToPointEnabled="True"
                            ValueChanged="Deck1SeekSlider_OnValueChanged"
                            PreviewMouseLeftButtonDown="Deck1SeekSlider_OnPreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="Deck1SeekSlider_OnPreviewMouseLeftButtonUp"/>
                    <TextBlock x:Name="Deck1SeekTimeLabel"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SurfaceForegroundBrush}"
                               Margin="0 0 0 4"
                               Text="0:00"/>
                  </Grid>
                  <WrapPanel>
                    <ToggleButton x:Name="Deck1PlayPauseToggle" Content="⏵" Width="28" Height="20" Margin="0 0 8 2" Checked="Deck1PlayPauseToggle_OnChecked" Unchecked="Deck1PlayPauseToggle_OnUnchecked"/>
                    <TextBlock Text="Громк." VerticalAlignment="Center" Foreground="{DynamicResource SurfaceForegroundBrush}" Margin="0 0 4 2"/>
                    <Slider x:Name="Deck1VolumeSlider" Width="100" Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1" ValueChanged="Deck1VolumeSlider_OnValueChanged">
                      <Slider.Resources>
                        <Style TargetType="Thumb" BasedOn="{StaticResource DeckSliderThumbStyle}" />
                      </Slider.Resources>
                    </Slider>
                    <Button Content="Затух" Width="56" Height="20" Margin="6 0 0 2" Click="Deck1FadeButton_OnClick" />
                    <TextBlock Text="Вывод" VerticalAlignment="Center" Foreground="{DynamicResource SurfaceForegroundBrush}" Margin="4 0 4 2"/>
                    <ComboBox x:Name="Deck1DeviceCombo" Width="Auto" MinWidth="110" MaxWidth="160" SelectionChanged="Deck1DeviceCombo_OnSelectionChanged" Style="{StaticResource DeckOutputComboBoxStyle}"/>
                  </WrapPanel>
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Row="1"
                    x:Name="Deck2DropArea"
                    Background="{DynamicResource SurfaceBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    AllowDrop="True"
                    Drop="Deck2_OnDrop"
                    DragEnter="Deck_OnDragEnter"
                    DragOver="Deck_OnDragOver"
                    Margin="0 2 0 0">
              <Grid Margin="4">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Дека 2" Foreground="{DynamicResource SurfaceForegroundBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                  <Button Grid.Column="1"
                          Width="16"
                          Height="16"
                          Margin="4 0 0 0"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Style="{StaticResource DeckClearButtonStyle}"
                          CommandParameter="2"
                          Click="DeckClearButton_OnClick" />
                </Grid>
                <TextBlock Grid.Row="1" x:Name="Deck2NowLabel" Text="Перетащите сюда трек" Foreground="{DynamicResource SurfaceForegroundBrush}" TextTrimming="CharacterEllipsis" PreviewMouseMove="DeckNowLabel_OnPreviewMouseMove"/>
                <StackPanel Grid.Row="2" Orientation="Vertical">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="Deck2SeekSlider"
                            Grid.Column="0"
                            Minimum="0"
                            Maximum="1"
                            Height="16"
                            Margin="0 0 6 4"
                            IsMoveToPointEnabled="True"
