                    AllowDrop="True"
                    Drop="Deck3_OnDrop"
                    DragEnter="Deck_OnDragEnter"
                    DragOver="Deck_OnDragOver"
                    Margin="0 2 0 0">
              <Grid Margin="4">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Дека 3" Foreground="{DynamicResource SurfaceForegroundBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                  <Button Grid.Column="1"
                          Width="16"
                          Height="16"
                          Margin="4 0 0 0"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Style="{StaticResource DeckClearButtonStyle}"
                          CommandParameter="3"
                          Click="DeckClearButton_OnClick" />
                </Grid>
                <TextBlock Grid.Row="1" x:Name="Deck3NowLabel" Text="Перетащите сюда трек" Foreground="{DynamicResource SurfaceForegroundBrush}" TextTrimming="CharacterEllipsis" PreviewMouseMove="DeckNowLabel_OnPreviewMouseMove"/>
                <StackPanel Grid.Row="2" Orientation="Vertical">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="Deck3SeekSlider"
                            Grid.Column="0"
                            Minimum="0"
                            Maximum="1"
                            Height="16"
                            Margin="0 0 6 4"
                            IsMoveToPointEnabled="True"
                            ValueChanged="Deck3SeekSlider_OnValueChanged"
                            PreviewMouseLeftButtonDown="Deck3SeekSlider_OnPreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="Deck3SeekSlider_OnPreviewMouseLeftButtonUp"/>
                    <TextBlock x:Name="Deck3SeekTimeLabel"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SurfaceForegroundBrush}"
                               Margin="0 0 0 4"
                               Text="0:00"/>
                  </Grid>
                  <WrapPanel>
                    <ToggleButton x:Name="Deck3PlayPauseToggle" Content="⏵" Width="28" Height="20" Margin="0 0 8 2" Checked="Deck3PlayPauseToggle_OnChecked" Unchecked="Deck3PlayPauseToggle_OnUnchecked"/>
                    <TextBlock Text="Громк." VerticalAlignment="Center" Foreground="{DynamicResource SurfaceForegroundBrush}" Margin="0 0 4 2"/>
                    <Slider x:Name="Deck3VolumeSlider" Width="100" Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1" ValueChanged="Deck3VolumeSlider_OnValueChanged">
                      <Slider.Resources>
